# ─────────────────────────────────────────────────────────────
# Fichier d'exemple — à copier en `.env` puis compléter.
# Le .env lui-même est dans .gitignore.
# ─────────────────────────────────────────────────────────────

# ── Base de données ──────────────────────────────────────────
DATABASE_URL=sqlite:///./scanner.db

# ── Celery / Redis ───────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── MinIO / S3 ───────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_SESSIONS=sessions
MINIO_SECURE=false

# ── Orchestrateur ────────────────────────────────────────────
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
DB_ECHO=false

# ── Daemon ───────────────────────────────────────────────────
DAEMON_ORCHESTRATOR_URL=http://localhost:8000
DAEMON_STORAGE_PATH=./daemon_storage
DAEMON_CAMERA_DRIVER=mock
# Options de driver caméra à compléter au chapitre 05
# (gphoto2 | picamera2 | mock)
